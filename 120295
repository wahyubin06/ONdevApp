<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>ONdev · Ojek & Kurir</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',Roboto,sans-serif; }
        body { background:#eef5f1; display:flex; justify-content:center; align-items:center; min-height:100vh; padding:20px 16px; }
        .container { max-width:420px; width:100%; background:white; border-radius:36px; padding:28px 20px 32px; box-shadow:0 20px 40px rgba(0,20,10,0.06); border:1px solid #cde3d8; text-align:center; }
        .logo-section { display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:8px; }
        .logo-icon { background:#1e8e46; width:60px; height:60px; border-radius:20px; display:flex; align-items:center; justify-content:center; box-shadow:0 8px 14px rgba(30,142,70,0.2); }
        .logo-icon i { font-size:32px; color:white; }
        h1 { font-size:32px; font-weight:800; color:#173e2b; letter-spacing:-0.5px; }
        .subtitle { font-size:14px; color:#4b7662; font-weight:500; margin-bottom:24px; }
        .service-menu { display:flex; flex-direction:column; gap:16px; margin-bottom:28px; }
        .menu-card { display:flex; align-items:center; gap:14px; background:#f9fdfb; border:1.5px solid #d2e5db; border-radius:24px; padding:16px 18px; text-decoration:none; color:inherit; transition:all 0.15s; box-shadow:0 4px 8px rgba(0,0,0,0.02); text-align:left; }
        .menu-card:active { background:#e6f3ec; border-color:#1e8e46; transform:scale(0.98); }
        .menu-icon { width:52px; height:52px; border-radius:18px; background:white; display:flex; align-items:center; justify-content:center; color:#1e8e46; font-size:26px; box-shadow:0 4px 8px rgba(0,0,0,0.04); border:1px solid #deede5; flex-shrink:0; }
        .menu-text { flex:1; }
        .menu-text h3 { font-size:17px; font-weight:700; color:#1e3a2c; margin-bottom:2px; }
        .menu-text .desc { font-size:12px; color:#5f7c6e; margin-bottom:4px; }
        .price-tag { display:inline-block; background:#e0f0e6; color:#1a5c3a; font-weight:700; font-size:13px; padding:4px 12px; border-radius:16px; margin-top:4px; }
        .footer-note { font-size:13px; color:#7aa290; margin-top:10px; }
        .footer-note i { color:#1e8e46; }
    </style>
</head>
<body>
<div class="container">
