<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Driver ONdev</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',Roboto,sans-serif; }
        body { background:#eef5f1; display:flex; justify-content:center; padding:16px 12px; min-height:100vh; }
        .app { max-width:450px; width:100%; }
        .header { background:white; border-radius:24px; padding:16px; display:flex; gap:12px; align-items:center; margin-bottom:16px; border:1px solid #cde3d8; }
        .logo { background:#1e8e46; width:44px; height:44px; border-radius:14px; display:flex; align-items:center; justify-content:center; color:white; font-size:24px; }
        .login-box { background:white; border-radius:24px; padding:20px; border:1px solid #d2e5db; margin-bottom:16px; }
        .btn { background:#1e8e46; border:none; border-radius:30px; padding:12px 18px; color:white; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; }
        .btn-wa { background:#25d366; }
        .card { background:white; border-radius:20px; padding:14px; margin-bottom:10px; border:1px solid #d2e5db; }
        .status { font-size:11px; padding:2px 8px; border-radius:12px; }
        .status.menunggu { background:#f0a04b; color:white; }
        .status.otw { background:#1e8e46; color:white; }
        .status.selesai { background:#2d6a4f; color:white; }
        .flex-between { display:flex; justify-content:space-between; align-items:center; }
        select { width:100%; padding:12px; border-radius:16px; border:1.5px solid #cde3d8; margin:12px 0; }
    </style>
</head>
<body>
<div class="app">
    <div class="header">
        <div class="logo"><i class="fas fa-motorcycle"></i></div>
        <div><h2>ONdev Driver</h2><small id="greeting">Silakan login</small></div>
    </div>
    <div id="loginPanel" class="login-box">
        <h3 style="color:#173e2b; margin-bottom:4px;">Login Driver</h3>
        <select id="driverSelect"><option value="">-- Pilih Driver --</option></select>
        <button class="btn" id="loginBtn" style="width:100%;">Masuk</button>
    </div>
    <div id="workPanel" style="display:none;">
        <div class="flex-between" style="margin-bottom:12px;"><h3 style="color:#173e2b;">📋 Job Saya</h3><button class="btn" id="refreshBtn"><i class="fas fa-sync-alt"></i></button></div>
        <div id="jobList"></div>
        <button class="btn btn-outline" id="logoutBtn" style="margin-top:12px; width:100%;">Ganti Driver</button>
    </div>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.9.0/firebase-app.js";
    import { getDatabase, ref, onValue, update, get } from "https://www.gstatic.com/firebasejs/10.9.0/firebase-database.js";

    // ⚠️ TEMPEL KONFIGURASI FIREBASE ANDA (SAMA SEPERTI ADMIN)
    const firebaseConfig = {
          apiKey: "AIzaSyBRTtppmk-TVTmFqXK3lvYrY2asDYwJU2w",
  authDomain: "ondave-backend.firebaseapp.com",
  databaseURL: "https://ondave-backend-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "ondave-backend",
  storageBucket: "ondave-backend.firebasestorage.app",
  messagingSenderId: "977512849672",
  appId: "1:977512849672:web:2742a594ee2864c813ccbd",
  measurementId: "G-QW9HG52EGM"
    };

    const app = initializeApp(firebaseConfig);
    const db = getDatabase(app);

    let currentDriverId = null;
    let currentDriverKey = null;
    let driversCache = {};

    function waLink(phone, text) {
        let n = (phone||'').replace(/\D/g, '');
        if (n.startsWith('0')) n = '62' + n.substring(1);
        else if (!n.startsWith('62')) n = '62' + n;
        return `https://wa.me/${n}?text=${encodeURIComponent(text)}`;
    }

    function renderJobs(ordersObj) {
        const orders = Object.entries(ordersObj||{}).map(([k,v]) => ({key:k, ...v}));
        const myJobs = orders.filter(o => o.driverId === currentDriverId && o.status !== 'selesai');
        const container = document.getElementById('jobList');
        if (!myJobs.length) {
            container.innerHTML = '<div style="text-align:center;padding:20px;color:#6f9b84;">Belum ada job.</div>';
            return;
        }
        container.innerHTML = myJobs.map(j => `
            <div class="card">
                <div class="flex-between"><strong>${j.customerName}</strong><span class="status ${j.status==='menunggu'?'menunggu':'otw'}">${j.status==='dalam perjalanan'?'OTW':j.status}</span></div>
                <div style="font-size:13px;">🟢 ${j.pickup}</div>
                <div style="font-size:13px;">🔴 ${j.destination}</div>
                <div style="font-size:12px;">ID: ${j.key}</div>
                <div style="margin-top:8px;">
                    ${j.status === 'menunggu' ? 
                        `<button class="btn take-btn" data-key="${j.key}"><i class="fas fa-play"></i> Ambil</button>` :
                        `<button class="btn finish-btn" data-key="${j.key}"><i class="fas fa-check"></i> Selesai</button>`
                    }
                    <a href="${waLink(j.customerPhone, `Halo ${j.customerName}, saya driver ONdev. Pesanan ${j.key} sedang diproses.`)}" target="_blank" class="btn btn-wa"><i class="fab fa-whatsapp"></i> Pelanggan</a>
                </div>
            </div>`).join('');

        document.querySelectorAll('.take-btn').forEach(b => b.addEventListener('click', () => updateStatus(b.dataset.key, 'dalam perjalanan')));
        document.querySelectorAll('.finish-btn').forEach(b => b.addEventListener('click', () => updateStatus(b.dataset.key, 'selesai')));
    }

    function updateStatus(key, status) {
        update(ref(db, 'orders/' + key), { status }).then(() => {
            if (status === 'selesai' && currentDriverKey) {
                get(ref(db, 'drivers/' + currentDriverKey)).then(snap => {
                    const drv = snap.val();
                    if (drv) update(ref(db, 'drivers/' + currentDriverKey), { trip: (drv.trip||0)+1 });
                });
            }
        });
    }

    // Ambil daftar driver
    onValue(ref(db, 'drivers'), snap => {
        driversCache = snap.val() || {};
        const select = document.getElementById('driverSelect');
        select.innerHTML = '<option value="">-- Pilih Driver --</option>';
        Object.entries(driversCache).forEach(([k,v]) => {
            const opt = document.createElement('option');
            opt.value = v.id;
            opt.setAttribute('data-key', k);
            opt.textContent = `${v.nama} (${v.id})`;
            select.appendChild(opt);
        });
    });

    // Dengarkan orders
    onValue(ref(db, 'orders'), snap => {
        if (currentDriverId) renderJobs(snap.val() || {});
    });

    document.getElementById('loginBtn').addEventListener('click', () => {
        const select = document.getElementById('driverSelect');
        const id = select.value;
        const key = select.options[select.selectedIndex]?.getAttribute('data-key');
        if (!id) return alert('Pilih driver.');
        currentDriverId = id;
        currentDriverKey = key;
        document.getElementById('greeting').textContent = `Halo, ${select.options[select.selectedIndex].text}`;
        document.getElementById('loginPanel').style.display = 'none';
        document.getElementById('workPanel').style.display = 'block';
    });

    document.getElementById('logoutBtn').addEventListener('click', () => {
        currentDriverId = null; currentDriverKey = null;
        document.getElementById('loginPanel').style.display = 'block';
        document.getElementById('workPanel').style.display = 'none';
        document.getElementById('greeting').textContent = 'Silakan login';
    });

    document.getElementById('refreshBtn').addEventListener('click', () => {});
</script>
</body>
</html>